<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book Appointment – MediConnect</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container">
    <div class="page-header">
      <h1>📅 Book an Appointment</h1>
      <p>Select a doctor, date and time to schedule your visit.</p>
    </div>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

    <div class="booking-card">
      <form action="/appointments/book" method="POST" class="booking-form">

        <div class="form-group">
          <label>Select Doctor</label>
          <select name="doctorId" required>
            <option value="">-- Choose a Doctor --</option>
            <% doctors.forEach(d => { %>
              <option value="<%= d.id %>"><%= d.name %> – <%= d.specialty %> (<%= d.hospital %>)</option>
            <% }); %>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Preferred Date</label>
            <input type="date" name="date" min="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          <div class="form-group">
            <label>Preferred Time</label>
            <select name="time" required>
              <option value="">-- Select Time --</option>
              <option>09:00 AM</option><option>09:30 AM</option>
              <option>10:00 AM</option><option>10:30 AM</option>
              <option>11:00 AM</option><option>11:30 AM</option>
              <option>02:00 PM</option><option>02:30 PM</option>
              <option>03:00 PM</option><option>03:30 PM</option>
              <option>04:00 PM</option><option>04:30 PM</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>Reason for Visit <span class="optional">(optional)</span></label>
          <textarea name="reason" rows="3" placeholder="Briefly describe your symptoms or reason..."></textarea>
        </div>

        <button type="submit" class="btn-full">Confirm Appointment</button>
      </form>
    </div>

    <div class="doctors-preview">
      <h3>Our Specialists</h3>
      <div class="doctors-grid">
        <% doctors.forEach(d => { %>
          <div class="doctor-card-sm">
            <div class="doctor-avatar"><%= d.name.split(' ').map(w=>w[0]).slice(1,3).join('') %></div>
            <div class="doctor-info-sm">
              <strong><%= d.name %></strong>
              <span><%= d.specialty %></span>
              <small><%= d.hospital %></small>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
