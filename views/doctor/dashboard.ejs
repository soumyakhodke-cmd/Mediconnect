<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctor Dashboard – MediConnect</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Doctor Navbar -->
  <nav class="navbar doctor-navbar">
    <div class="nav-container">
      <a class="nav-brand" href="/doctor/dashboard">
        <span class="brand-icon">🏥</span> MediConnect <span class="portal-badge">Doctor Portal</span>
      </a>
      <ul class="nav-links">
        <li><a href="/doctor/dashboard" class="active">Dashboard</a></li>
        <li><a href="/doctor/reports">Uploaded Reports</a></li>
        <li><a href="/doctor/logout" class="btn-nav-logout">Logout (<%= doctor.name.split(' ').slice(0,2).join(' ') %>)</a></li>
      </ul>
    </div>
  </nav>

  <div class="page-container">
    <!-- Doctor Profile Banner -->
    <div class="doctor-banner">
      <div class="doctor-banner-avatar"><%= doctor.avatar %></div>
      <div class="doctor-banner-info">
        <h1><%= doctor.name %></h1>
        <p><%= doctor.specialty %> · <%= doctor.hospital %></p>
        <p class="doctor-email">📧 <%= doctor.email %></p>
      </div>
      <div class="doctor-stats">
        <div class="stat-box">
          <span class="stat-num"><%= appointments.length %></span>
          <span class="stat-label">Total Bookings</span>
        </div>
        <div class="stat-box">
          <span class="stat-num"><%= appointments.filter(a=>a.status==='Pending').length %></span>
          <span class="stat-label">Pending</span>
        </div>
        <div class="stat-box">
          <span class="stat-num"><%= appointments.filter(a=>a.status==='Confirmed').length %></span>
          <span class="stat-label">Confirmed</span>
        </div>
      </div>
    </div>

    <!-- Appointments Section -->
    <section class="section">
      <h2>📋 Patient Appointments</h2>

      <% if (appointments.length === 0) { %>
        <div class="empty-state">
          <p>No appointments booked with you yet.</p>
        </div>
      <% } else { %>
        <!-- Filter tabs -->
        <div class="filter-tabs">
          <button class="tab-btn active" data-filter="all">All (<%= appointments.length %>)</button>
          <button class="tab-btn" data-filter="pending">Pending (<%= appointments.filter(a=>a.status==='Pending').length %>)</button>
          <button class="tab-btn" data-filter="confirmed">Confirmed (<%= appointments.filter(a=>a.status==='Confirmed').length %>)</button>
          <button class="tab-btn" data-filter="completed">Completed (<%= appointments.filter(a=>a.status==='Completed').length %>)</button>
          <button class="tab-btn" data-filter="cancelled">Cancelled (<%= appointments.filter(a=>a.status==='Cancelled').length %>)</button>
        </div>

        <div class="appt-list" id="apptList">
          <% appointments.slice().reverse().forEach(a => { %>
            <div class="appt-card doctor-appt-card" data-status="<%= a.status.toLowerCase() %>">
              <div class="appt-meta">
                <div class="appt-patient-avatar">
                  <%= a.patientName.split(' ').map(w=>w[0]).slice(0,2).join('') %>
                </div>
                <div class="appt-details">
                  <strong><%= a.patientName %></strong>
                  <span>📧 <%= a.patientEmail %></span>
                  <small>📅 <%= a.date %> at <%= a.time %></small>
                  <% if (a.reason) { %><small>📝 Reason: <%= a.reason %></small><% } %>
                  <small class="booked-at">Booked on <%= new Date(a.bookedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></small>
                </div>
              </div>

              <div class="appt-actions">
                <div class="appt-status status-<%= a.status.toLowerCase() %>"><%= a.status %></div>

                <!-- Status update form -->
                <form action="/doctor/appointment/<%= a.id %>/status" method="POST" class="status-form">
                  <select name="status" onchange="this.form.submit()" class="status-select">
                    <option value="Pending"   <%= a.status==='Pending'   ? 'selected':'' %>>Pending</option>
                    <option value="Confirmed" <%= a.status==='Confirmed' ? 'selected':'' %>>Confirmed</option>
                    <option value="Completed" <%= a.status==='Completed' ? 'selected':'' %>>Completed</option>
                    <option value="Cancelled" <%= a.status==='Cancelled' ? 'selected':'' %>>Cancelled</option>
                  </select>
                </form>

                <!-- Upload report button -->
                <a href="/doctor/appointment/<%= a.id %>/upload" class="btn-upload">
                  📤 Upload Report
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </div>

  <footer class="footer">
    <div class="footer-bottom"><p>© 2024 MediConnect Doctor Portal. All rights reserved.</p></div>
  </footer>

  <script src="/js/main.js"></script>
  <script>
    // Filter tabs
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        document.querySelectorAll('.doctor-appt-card').forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.status === filter) ? 'flex' : 'none';
        });
      });
    });
    // Auto-refresh notification
    let currentApptCount = <%= appointments.length %>;
    
    // Check for new appointments every 10 seconds
    setInterval(async () => {
      try {
        const res = await fetch('/doctor/api/appointments/count');
        const data = await res.json();
        
        if (data.count > currentApptCount) {
          // If a toast doesn't already exist, create one
          if (!document.getElementById('refresh-toast')) {
            const toast = document.createElement('div');
            toast.id = 'refresh-toast';
            // Modern, vibrant design for the toast to match premium aesthetics
            toast.style.cssText = "position:fixed; bottom:30px; right:30px; background:linear-gradient(135deg, #00C6FF, #0072FF); color:white; padding:16px 24px; border-radius:12px; cursor:pointer; box-shadow:0 10px 25px rgba(0,114,255,0.3); z-index:9999; font-family:'Inter', sans-serif; font-weight:600; display:flex; align-items:center; gap:12px; animation: slideInUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);";
            toast.innerHTML = `<span style="font-size:20px;">🔔</span> <span>New appointment! Click to refresh</span>`;
            
            // Hover effect using events
            toast.onmouseenter = () => toast.style.transform = 'translateY(-3px)';
            toast.onmouseleave = () => toast.style.transform = 'translateY(0)';
            toast.style.transition = 'transform 0.2s';
            
            toast.onclick = () => window.location.reload();
            document.body.appendChild(toast);

            // Add animation keyframes
            if (!document.getElementById('toast-keyframes')) {
              const style = document.createElement('style');
              style.id = 'toast-keyframes';
              style.innerHTML = "@keyframes slideInUp { from { transform: translateY(100px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }";
              document.head.appendChild(style);
            }
          }
        }
      } catch (err) {
         console.error('Failed to check for new appointments', err);
      }
    }, 10000);
  </script>
</body>
</html>
