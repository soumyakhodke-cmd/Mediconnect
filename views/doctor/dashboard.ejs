<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Doctor Dashboard – MediConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <!-- Doctor Navbar (Floating Capsule) -->
  <nav class="navbar doctor-navbar">
    <div class="nav-container">
      <a class="nav-brand" href="/doctor/dashboard">
        <i data-lucide="activity" class="brand-icon"></i> MediConnect <span class="portal-badge" style="background: var(--primary); color: white;">Doctor Portal</span>
      </a>
      <ul class="nav-links">
        <li><a href="/doctor/dashboard" class="active">Dashboard</a></li>
        <li><a href="/doctor/reports">Reports</a></li>
        <li><a href="/doctor/logout" class="btn-nav-logout" style="border-radius: var(--radius-pill); padding: 0.5rem 1.2rem;">Logout (<%= doctor.name.split(' ').slice(0,1) %>)</a></li>
      </ul>
    </div>
  </nav>

  <div class="page-container">
    <!-- Doctor Profile Banner -->
    <div class="doctor-banner reveal">
      <div class="doctor-banner-avatar"><%= doctor.avatar %></div>
      <div class="doctor-banner-info">
        <h1><%= doctor.name %></h1>
        <p><%= doctor.specialty %> · <%= doctor.hospital %></p>
        <p class="doctor-email"><i data-lucide="mail" style="width:14px; vertical-align:middle;"></i> <%= doctor.email %></p>
      </div>
      <div class="doctor-stats">
        <div class="stat-box">
          <span class="stat-num"><%= appointments.length %></span>
          <span class="stat-label">Total Bookings</span>
        </div>
        <div class="stat-box">
          <span class="stat-num"><%= appointments.filter(a=>a.status==='Pending').length %></span>
          <span class="stat-label">Pending</span>
        </div>
        <div class="stat-box">
          <span class="stat-num"><%= appointments.filter(a=>a.status==='Confirmed').length %></span>
          <span class="stat-label">Confirmed</span>
        </div>
      </div>
    </div>

    <!-- Appointments Section -->
    <section class="section reveal">
      <h2 style="margin-bottom: 2rem;"><i data-lucide="users" style="vertical-align:middle; margin-right:8px;"></i> Patient Appointments</h2>

      <% if (appointments.length === 0) { %>
        <div class="empty-state">
          <p>No appointments booked with you yet.</p>
        </div>
      <% } else { %>
        <!-- Filter tabs -->
        <div class="filter-tabs">
          <button class="tab-btn active" data-filter="all">All (<%= appointments.length %>)</button>
          <button class="tab-btn" data-filter="pending">Pending</button>
          <button class="tab-btn" data-filter="confirmed">Confirmed</button>
          <button class="tab-btn" data-filter="completed">Completed</button>
          <button class="tab-btn" data-filter="cancelled">Cancelled</button>
        </div>

        <div class="appt-list" id="apptList">
          <% appointments.slice().reverse().forEach(a => { %>
            <div class="appt-card doctor-appt-card" data-status="<%= a.status.toLowerCase() %>">
              <div class="appt-meta">
                <div class="appt-patient-avatar">
                  <%= a.patientName.split(' ').map(w=>w[0]).slice(0,2).join('') %>
                </div>
                <div class="appt-details">
                  <strong><%= a.patientName %></strong>
                  <span><i data-lucide="mail" style="width:12px;"></i> <%= a.patientEmail %></span>
                  <small><i data-lucide="calendar" style="width:12px;"></i> <%= a.date %> at <%= a.time %></small>
                  <% if (a.reason) { %><small><i data-lucide="message-square" style="width:12px;"></i> <%= a.reason %></small><% } %>
                </div>
              </div>

              <div class="appt-actions">
                <div class="appt-status status-<%= a.status.toLowerCase() %>"><%= a.status %></div>

                <form action="/doctor/appointment/<%= a.id %>/status" method="POST" class="status-form">
                  <select name="status" onchange="this.form.submit()" class="status-select">
                    <option value="Pending"   <%= a.status==='Pending'   ? 'selected':'' %>>Pending</option>
                    <option value="Confirmed" <%= a.status==='Confirmed' ? 'selected':'' %>>Confirmed</option>
                    <option value="Completed" <%= a.status==='Completed' ? 'selected':'' %>>Completed</option>
                    <option value="Cancelled" <%= a.status==='Cancelled' ? 'selected':'' %>>Cancelled</option>
                  </select>
                </form>

                <div style="display: flex; gap: 8px;">
                  <a href="/doctor/appointment/<%= a.id %>/upload" class="btn-upload" title="Upload Report">
                    <i data-lucide="upload-cloud" style="width:14px;"></i>
                  </a>
                  
                  <% if (['Cancelled', 'Completed'].includes(a.status)) { %>
                    <form action="/doctor/appointment/delete/<%= a.id %>" method="POST" style="margin:0;">
                      <button type="submit" class="btn-upload" style="background: var(--danger-light); color: var(--danger);" title="Delete Record" onclick="return confirm('Delete this record?');">
                        <i data-lucide="trash-2" style="width:14px;"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </div>

  <footer class="footer">
    <div class="footer-bottom"><p>© 2026 MediConnect Doctor Portal. All rights reserved.</p></div>
  </footer>

  <script>
    const reveal = () => {
      const reveals = document.querySelectorAll('.reveal');
      reveals.forEach(el => {
        const windowHeight = window.innerHeight;
        const revealTop = el.getBoundingClientRect().top;
        if (revealTop < windowHeight - 80) el.classList.add('active');
      });
    };

    window.addEventListener('scroll', reveal);
    window.addEventListener('load', reveal);

    document.addEventListener('DOMContentLoaded', () => {
      if (window.lucide) lucide.createIcons();
      setTimeout(reveal, 100);

      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const filter = btn.dataset.filter;
          document.querySelectorAll('.doctor-appt-card').forEach(card => {
            card.style.display = (filter === 'all' || card.dataset.status === filter) ? 'flex' : 'none';
          });
          reveal();
        });
      });
    });
  </script>
</body>
</html>
